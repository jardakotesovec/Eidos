msgid "plugins.themes.eidos.name"
msgstr "Edios"

msgid "plugins.themes.eidos.description"
msgstr "An official theme from PKP that is highly configurable."

msgid "plugins.themes.eidos.changeLanguage"
msgstr "Change Language"

msgid "plugins.themes.eidos.loggedInAs"
msgstr "Logged in as <strong>{$username}</strong>"

msgid "plugins.themes.eidos.loginOrRegister"
msgstr "Login or Register"

msgid "plugins.themes.eidos.account"
msgstr "Account"

msgid "plugins.themes.eidos.privacyPolicy"
msgstr "Privacy Policy"

msgid "plugins.themes.eidos.usesOjs"
msgstr "Hosted using <a href=\"{$urlOJS}\">Open Journal Systems</a> by <a href=\"{$urlPKP}\">Public Knowledge Project</a>."

msgid "plugins.themes.eidos.option.header.label"
msgstr "Header"

msgid "plugins.themes.eidos.option.header.description"
msgstr "Choose the layout of the logo and navigation menus in the header of your site. The default layouts work for most sites. Only use the One Line option if you have a small number of items in your navigation menu."

msgid "plugins.themes.eidos.option.header.default"
msgstr "Default"

msgid "plugins.themes.eidos.option.header.default-boxed"
msgstr "Boxed Layout"

msgid "plugins.themes.eidos.option.header.line"
msgstr "One Line (logo and navigation menu on one line)"

msgid "plugins.themes.eidos.option.tagline.label"
msgstr "Tagline"

msgid "plugins.themes.eidos.option.tagline.description"
msgstr "A short description, motto or title to display beside the journal's logo. This will not be displayed if no logo is uploaded."

msgid "plugins.themes.eidos.option.homepageImagePosition.label"
msgstr "Homepage Image Position"

msgid "plugins.themes.eidos.option.homepageImagePosition.description"
msgstr "Choose how to display the Homepage Image on the header of your website. The Homepage Image can be uploaded in the <a href='#appearance/appearance-setup'>Appearance > Setup</a> settings."

msgid "plugins.themes.eidos.option.homepageImagePosition.above"
msgstr "Above Header"

msgid "plugins.themes.eidos.option.homepageImagePosition.behind"
msgstr "Behind Header"

msgid "plugins.themes.eidos.option.homepageImagePosition.below"
msgstr "Below Header"

msgid "plugins.themes.eidos.option.homepageImagePosition.none"
msgstr "Don't show the homepage image in the header"

msgid "plugins.themes.eidos.option.siteWidth.label"
msgstr "Site Width"

msgid "plugins.themes.eidos.option.siteWidth.description"
msgstr "Choose how your site should appear when viewed on on very large screens. If you use the Homepage Image in your header, you may want to choose Fixed Width to prevent the image from becoming too large."

msgid "plugins.themes.eidos.option.siteWidth.full"
msgstr "Full Width - The header and footer will extend the full width of the screen."

msgid "plugins.themes.eidos.option.siteWidth.fixed"
msgstr "Fixed Width - On very large screens, the header and footer will not be wider than then page content."
