@php
    $homepageImage = $currentContext->getLocalizedData('homepageImage');
@endphp

<header
    class="
        header-desktop
        header-desktop-{{ $activeTheme->getOption('header') }}
        header-desktop-image-{{ $activeTheme->getOption('homepageImagePosition') }}
    "
>
    @if ($homepageImage && in_array($activeTheme->getOption('homepageImagePosition'), ['above']))
        <div class="header-desktop-above">
            <img class="header-desktop-image" src="{{ $publicFilesDir }}/{{ $homepageImage['uploadName'] }}"
                alt="{{ $homepageImage['altText'] }}">
        </div>
    @endif
    <div class="header-desktop-inner">
        @if ($homepageImage && $activeTheme->getOption('homepageImagePosition') === 'behind')
            <div class="header-desktop-behind">
                @if ($activeTheme->getOption('homepageImagePosition') === 'behind-pattern')
                    <div class="header-desktop-image"
                        style="background-image: url('{{ $publicFilesDir }}/{{ $homepageImage['uploadName'] }}');"></div>
                @else
                    <img class="header-desktop-image" src="{{ $publicFilesDir }}/{{ $homepageImage['uploadName'] }}"
                        alt="{{ $homepageImage['altText'] }}">
                @endif
            </div>
        @endif
        <div class="header-desktop-inner-content">
            @if (in_array($activeTheme->getOption('header'), ['boxed']))
                <div class="header-desktop-row">
                    <x-eidostheme::header-desktop-pubids />
                    <x-eidostheme::header-utility-menu />
                </div>
                <div class="header-desktop-row">
                    <div class="header-desktop-boxed-line"></div>
                </div>
            @endif
            <div class="header-desktop-row">
                <div class="header-desktop-context">
                    <a href="{{ ViewHelper::url(['page' => 'index']) }}" class="tab-focus">
                        @if ($displayPageHeaderLogo)
                            <div class="sr-only">
                                {{ $currentContext->getLocalizedName() }}
                            </div>
                            <img class="header-desktop-logo"
                                src="{{ $publicFilesDir }}/{{ $displayPageHeaderLogo['uploadName'] }}">
                        @else
                            <div class="header-desktop-name header-desktop-name-{{ $getStringSize($contextName) }}">
                                {{ $currentContext->getLocalizedName() }}
                            </div>
                        @endif
                    </a>
                    @if (
                        $displayPageHeaderLogo &&
                            $activeTheme->getLocalizedOption('tagline') &&
                            in_array($activeTheme->getOption('header'), ['default', 'boxed']))
                        <div class="header-desktop-tagline">
                            {{ $activeTheme->getLocalizedOption('tagline') }}
                        </div>
                    @endif
                </div>
                @if (in_array($activeTheme->getOption('header'), ['boxed', 'line']))
                    <nav class="header-desktop-nav-main-line" id="skip-to-nav-desktop">
                        @loadMenu(['name' => 'primary', 'id' => 'nav-desktop-primary', 'path' => 'components/menu-dropdowns'])
                    </nav>
                @endif
                @if (in_array($activeTheme->getOption('header'), ['default', 'line']))
                    <x-eidostheme::header-utility-menu />
                @endif
            </div>
        </div>
    </div>
    @if (in_array($activeTheme->getOption('header'), ['default']))
        <div class="header-desktop-row">
            <nav class="header-desktop-nav-main" id="skip-to-nav-desktop">
                @loadMenu(['name' => 'primary', 'id' => 'nav-desktop-primary', 'path' => 'components/menu-dropdowns'])
            </nav>
            <x-eidostheme::header-desktop-pubids />
        </div>
    @endif
    @if ($homepageImage && in_array($activeTheme->getOption('homepageImagePosition'), ['below', 'below-center']))
        <div class="header-desktop-below">
            <img class="header-desktop-image" src="{{ $publicFilesDir }}/{{ $homepageImage['uploadName'] }}"
                alt="{{ $homepageImage['altText'] }}">
        </div>
    @endif
</header>
